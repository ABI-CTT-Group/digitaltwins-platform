# ------------------------------------------------------------
# env — per-deployment configuration (STARTER TEMPLATE)
#
# Copy this file to your deployment's data dir as `env`, then edit the
# values for your host. Source it (plus secrets.env) before running the
# ansible playbook:
#
#     source /mnt/install_src/data/secrets.env
#     source /mnt/install_src/data/env
#
# This file holds ONLY non-secret deployment config. Secrets live in
# secrets.env. Neither the live `env` nor secrets.env is committed to git;
# this template is the committed starting point.
# ------------------------------------------------------------

## For localhost / local development (http, no strict hostname)
#export PLATFORM_PROTOCOL=http
#export PLATFORM_DOMAIN=localhost
#export KC_HOSTNAME_STRICT=false
#export KC_HOSTNAME_STRICT_HTTPS=false

## For deployment to a public domain over https
export PLATFORM_PROTOCOL=https
export PLATFORM_DOMAIN=your.domain.example
export KC_HOSTNAME_STRICT=true
export KC_HOSTNAME_STRICT_HTTPS=true
