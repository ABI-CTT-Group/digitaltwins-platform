{
  "Name": "DigitalTwins PACS",
  "RemoteAccessAllowed": true,
  "AuthenticationEnabled": false,
  "UserContentType": {
    "clinicalRecords": [
      1025,
      "text/csv"
    ],
    "accessionNumbers": [
      1026,
      "text/plain"
    ]
  },
  "DicomAet": "${ORTHANC_AET}",
  "DicomPort": 4242,
  "HttpPort": 8042,
  "DicomModalities": {
    "PEER": [
      "${PEER_AET}",
      "${PEER_HOST}",
      4242
    ]
  },
  "StorageDirectory": "/var/lib/orthanc/db",
  "DicomWeb": {
    "Enable": true,
    "Root": "/dicom-web/"
  },
  "Python": {
    "Path": "/etc/orthanc/deidentification.py",
    "Verbose": false
  },
  "OrthancExplorer2": {
    "IsDefaultUI": true,
    "UiOptions": {
      "EnableShares": true,
      "ShareDuration": 0
    },
    "Keycloak": {
      "Enable": true,
      "Url": "${ORTHANC_KEYCLOAK_URL}",
      "Realm": "digitaltwins",
      "ClientId": "orthanc"
    }
  },
  "Authorization": {
    "WebServiceRootUrl": "http://${ORTHANC_AUTH_SERVICE_HOST:-orthanc-auth-service}:8000/",
    "WebServiceUsername": "orthanc-auth-user",
    "WebServicePassword": "${ORTHANC_AUTH_SERVICE_PASSWORD}",
    "StandardConfigurations": [
      "orthanc",
      "orthanc-explorer-2",
      "stone-webviewer"
    ],
    "UncheckedFolders": [],
    "CheckedLevel": "studies"
  },
  "RestApiWriteToFileSystemEnabled": true
}