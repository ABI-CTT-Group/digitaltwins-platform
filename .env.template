# ------------------------------------------------------------------
# IAM service
# ------------------------------------------------------------------
## Keycloak
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=${KC_BOOTSTRAP_ADMIN_PASSWORD}
KC_HOSTNAME_STRICT=true
KC_HOSTNAME_STRICT_HTTPS=true

## Keycloak database (shared postgres)
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=${KEYCLOAK_DB_PASSWORD}

# ------------------------------------------------------------------
# Platform
# ------------------------------------------------------------------
PLATFORM_DOMAIN=${PLATFORM_DOMAIN}
PLATFORM_PROTOCOL=${PLATFORM_PROTOCOL}
COMPOSE_PROJECT_NAME=digitaltwins-platform
DOCKER_NETWORK_NAME=digitaltwins

# ------------------------------------------------------------------
# Portal service
# repo: https://github.com/ABI-CTT-Group/DigitalTWINS-Portal
# ------------------------------------------------------------------
PORTAL_BACKEND_HOST=${PLATFORM_DOMAIN}
PORTAL_KEYCLOAK_BASE_URL=${PLATFORM_PROTOCOL}://${PLATFORM_DOMAIN}/auth
DIGITALTWINS_API_BASE_URL=http://digitaltwins-api
DIGITALTWINS_API_PORT=8010
PORTAL_BACKEND_PORT=8001

# ------------------------------------------------------------------
# Metadata service (SEEK)
# ------------------------------------------------------------------
DHO_TERMS=standard
LDH_RELEASE=v0.3.2
NGINX_CONF=nginx.conf.http
RAILS_RELATIVE_URL_ROOT=/seek

## Postgres
POSTGRES_USER=admin
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_DB=digitaltwins
PGADMIN_DEFAULT_EMAIL=your.email@example.com
PGADMIN_DEFAULT_PASSWORD=${PGADMIN_DEFAULT_PASSWORD}

## SEEK MySQL
MYSQL_ROOT_PASSWORD=${MYSQL_ROOT_PASSWORD}
MYSQL_PASSWORD=${MYSQL_PASSWORD}

## Gen3
GEN3_ENABLED=false
GEN3_ENDPOINT=https://gen3
GEN3_CRED_FILE=./credentials.json
GEN3_SSL_CERT=./ca.pem

# ------------------------------------------------------------------
# Storage service (MinIO)
# ------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=${MINIO_ROOT_PASSWORD}
MINIO_SERVER_ACCESS_KEY=minioadmin
MINIO_SERVER_SECRET_KEY=${MINIO_SERVER_SECRET_KEY}
MINIO_BROWSER=off
MINIO_BROWSER_REDIRECT_URL=${PLATFORM_PROTOCOL}://${PLATFORM_DOMAIN}/minio-console

# ------------------------------------------------------------------
# Workflow service (Airflow)
# ------------------------------------------------------------------
AIRFLOW_UID=1001
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=${_AIRFLOW_WWW_USER_PASSWORD}
AIRFLOW_PORT=8002
AIRFLOW__CORE__FERNET_KEY=${AIRFLOW__CORE__FERNET_KEY}
AIRFLOW__API_AUTH__JWT_SECRET=${AIRFLOW__API_AUTH__JWT_SECRET}
AIRFLOW__API__SECRET_KEY=${AIRFLOW__API__SECRET_KEY}
AIRFLOW_KEYCLOAK_CLIENT_ID=airflow
AIRFLOW_KEYCLOAK_CLIENT_SECRET=${AIRFLOW_KEYCLOAK_CLIENT_SECRET}
AIRFLOW_PUBLIC_URL=${PLATFORM_PROTOCOL}://${PLATFORM_DOMAIN}/airflow
AIRFLOW_ENDPOINT=http://airflow-apiserver:8080/airflow
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=${AIRFLOW_PASSWORD}
AIRFLOW_WORKSPACE=
AIRFLOW_ENABLED=true
AIRFLOW_VERSION=3

## Airflow database (shared postgres)
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=${AIRFLOW_DB_PASSWORD}
AIRFLOW_DB_NAME=airflow

# ------------------------------------------------------------------
# Notebook service (JupyterHub)
# ------------------------------------------------------------------
JUPYTERHUB_PORT=8017
JUPYTERHUB_PUBLIC_URL=${PLATFORM_PROTOCOL}://${PLATFORM_DOMAIN}/jupyterhub
JUPYTERHUB_CLIENT_ID=jupyterhub
JUPYTERHUB_CLIENT_SECRET=${JUPYTERHUB_CLIENT_SECRET}
# Generate with: openssl rand -hex 32
JUPYTERHUB_CRYPT_KEY=${JUPYTERHUB_CRYPT_KEY}
JUPYTERHUB_ALLOWED_GROUPS=admin,researcher
JUPYTERHUB_ADMIN_GROUPS=admin
JUPYTERHUB_ADMIN_USERS=admin

# ------------------------------------------------------------------
# PACS service (Orthanc — two instances)
# ------------------------------------------------------------------
ORTHANC_1_AET=ORTHANC1
ORTHANC_2_AET=ORTHANC2
ORTHANC_AUTH_SERVICE_PASSWORD=${ORTHANC_AUTH_SERVICE_PASSWORD}
# Generate with: openssl rand -hex 32
ORTHANC_AUTH_SECRET_KEY=${ORTHANC_AUTH_SECRET_KEY}
# Must match value in Keycloak orthanc client credentials tab
ORTHANC_KEYCLOAK_CLIENT_SECRET=${ORTHANC_KEYCLOAK_CLIENT_SECRET}
ORTHANC_BIND_ADDRESS=127.0.0.1

# ------------------------------------------------------------------
# EHR service
# ------------------------------------------------------------------
# hapi-fhir

# ------------------------------------------------------------------
# API service
# ------------------------------------------------------------------
KEYCLOAK_ENABLED=true
KEYCLOAK_BASE_URL=http://keycloak:8080/auth
KEYCLOAK_REALM=digitaltwins
KEYCLOAK_ALGORITHM=RS256
KEYCLOAK_CLIENT_ID=api
KEYCLOAK_CLIENT_SECRET=${KEYCLOAK_CLIENT_SECRET}
SEEK_ENABLED=true
SEEK_BASE_URL=http://seek:3000/seek
SEEK_API_TOKEN=${SEEK_API_TOKEN}
POSTGRES_ENABLED=true
POSTGRES_HOST=database
POSTGRES_PORT=5432
MINIO_ENABLED=true
MINIO_ENDPOINT=http://minio:9000
IRODS_ENABLED=false
IRODS_HOST=irods
IRODS_PORT=8005
IRODS_USER=
IRODS_PASSWORD=
IRODS_ZONE=
IRODS_PROJECT_ROOT=
DATABRICKS_ENABLED=false

# ------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------
REDIS_PORT=8016
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_BIND_ADDRESS=0.0.0.0

# ------------------------------------------------------------------
# Bind addresses
# ------------------------------------------------------------------
PORTAL_FRONTEND_BIND_ADDRESS=0.0.0.0
PORTAL_BACKEND_BIND_ADDRESS=0.0.0.0
DIGITALTWINS_API_BIND_ADDRESS=0.0.0.0
MINIO_BIND_ADDRESS=0.0.0.0
AIRFLOW_BIND_ADDRESS=0.0.0.0
AIRFLOW_POSTGRES_BIND_ADDRESS=0.0.0.0
AIRFLOW_POSTGRES_PORT=8013
POSTGRES_BIND_ADDRESS=0.0.0.0
KEYCLOAK_BIND_ADDRESS=127.0.0.1
ORTHANC_BIND_ADDRESS=127.0.0.1
HAPI_FHIR_BIND_ADDRESS=127.0.0.1
JUPYTERLAB_BIND_ADDRESS=127.0.0.1
