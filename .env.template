PROJECT_NAME=digitaltwins-platform
# ------------------------------------------------------------------
# IAM service
# ------------------------------------------------------------------
## Keycloak
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin
#KC_HTTPS_KEY_STORE_PASSWORD=admin
KEYCLOAK_VERIFY_SSL=false

# ---- Keycloak's public address ----------------------------------------------------
# Keycloak sits BEHIND the edge gateway at <public-url>/auth, sharing its port and cert.
# It cannot stay on a plain-HTTP :8009 once the portal is served over TLS: a browser on
# an https:// page is blocked from calling an http:// endpoint (mixed active content).
#
# This URL is the `iss` claim in every token Keycloak issues, so FOUR settings must name
# the EXACT same address. If one drifts, only that consumer's logins fail — with an
# issuer mismatch, while everything else keeps working — which makes it a genuinely
# annoying bug to track down. They are, in this file:
#
#   KC_HOSTNAME               — what Keycloak thinks it is (below)
#   KEYCLOAK_PUBLIC_URL       — JupyterHub's authorize redirect (below)
#   PORTAL_KEYCLOAK_BASE_URL  — portal SPA + portal-backend (Portal section)
#   ORTHANC_KEYCLOAK_URL      — Orthanc OE2 login redirect (PACS section)
#
# The defaults below work as-is for a single-machine run (the gateway owns port 80). For
# any real deployment replace `localhost` with your host or domain in ALL FOUR, and use
# https:// once NGINX_MODE=ssl. The realm's redirectUris / webOrigins must match too.
KC_HOSTNAME=http://localhost/auth
KEYCLOAK_PUBLIC_URL=http://localhost/auth

# The context path Keycloak serves from. Keycloak 17+ dropped the historical /auth prefix
# and serves from the root by default; this puts it back, which is what every URL above
# and below assumes. Change it and all of them change with it.
KC_HTTP_RELATIVE_PATH=/auth

# Container-to-container Keycloak URL — JupyterHub's server-side token exchange and
# userinfo calls. Goes straight to the keycloak service on the shared Docker network and
# never leaves it, so it stays plain HTTP and does NOT change when you move to TLS.
KEYCLOAK_INTERNAL_URL=http://keycloak:8080/auth

# ------------------------------------------------------------------
# Portal service
# repo: https://github.com/ABI-CTT-Group/DigitalTWINS-Portal
# ------------------------------------------------------------------
# global
PORTAL_BACKEND_HOST=YOUR_DOCKER_HOST_IP_HERE
# Public scheme of the portal. Decides whether portal-backend generates http:// or
# https:// URLs (workflow metadata, MinIO presigned links, CORS origins).
SSL=false

# ------------------------------------------------------------------
# Edge gateway (services/nginx)
# ------------------------------------------------------------------
# Which server shell the gateway mounts: `http` or `ssl`.
#
# SSL and NGINX_MODE answer two DIFFERENT questions and are deliberately separate:
#   SSL        = "what scheme do browsers reach us on"  (portal backend's concern)
#   NGINX_MODE = "does the gateway itself terminate TLS" (the edge's concern)
#
# Normally they agree: SSL=true → NGINX_MODE=ssl.
# They diverge when TLS is terminated by a load balancer IN FRONT of the gateway:
# then it is SSL=true + NGINX_MODE=http — public https, plain http into the gateway.
NGINX_MODE=http

# Host directory holding the gateway's TLS certs (only read when NGINX_MODE=ssl).
# Defaults to the gateway's own directory — it is the only service that reads them.
# Filenames must match what services/nginx/conf/ssl/default.conf points at.
# Point this elsewhere for a real deployment, e.g. /etc/letsencrypt/live/<domain>.
SSL_CERT_DIR=./services/nginx/certs
# Portal frontend
BACKEND_PORT=8000
# Keycloak as the portal's SPA and backend see it. One of the four addresses that must
# all be identical — see the note under KC_HOSTNAME at the top of this file.
#
PORTAL_KEYCLOAK_BASE_URL=http://<HOST_IP>/auth
# Portal backend
DIGITALTWINS_API_BASE_URL=http://digitaltwins-api
DIGITALTWINS_API_PORT=8000

