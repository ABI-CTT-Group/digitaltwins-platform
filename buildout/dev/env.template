# For accessing the bucket nominated in the backend.tf
#
export AWS_ACCESS_KEY_ID=xxxxx
export AWS_SECRET_ACCESS_KEY=xxxxx

# Grafana Helm deployment (see helm_mod)
export GRAFANA_ADMIN_PASSWORD=
export GRAFANA_OAUTH_SECRET=

# Mimir Helm deployment (see install_observability_airgap.yaml)
# MIMIR_MINIO_ROOT_USER / SECRET_KEY are the credentials for the MinIO instance
# that Mimir deploys internally for block storage — separate from the platform MinIO.
export MIMIR_MINIO_ROOT_USER=
export MIMIR_MINIO_SECRET_KEY=
