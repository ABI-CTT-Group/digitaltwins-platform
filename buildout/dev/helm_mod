export KUBECONFIG=~/.kube/config

# These must be set in the environment before running this script.
# They are NOT stored here — the old value was rotated after accidental exposure.
: ${GRAFANA_OAUTH_SECRET:?}
: ${GRAFANA_ADMIN_PASSWORD:?}

helm upgrade grafana ./observability/charts/grafana-10.5.4.tgz \
  -n grafana \
  -f observability/grafana-values.yaml \
  --set adminUser=admin \
  --set adminPassword=$GRAFANA_ADMIN_PASSWORD \
  --set assertNoLeakedSecrets=false \
  --set "grafana\\.ini.auth\\.generic_oauth.client_secret=$GRAFANA_OAUTH_SECRET"
